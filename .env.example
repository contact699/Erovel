# NowPayments crypto payment processor
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_IPN_CALLBACK_URL=

# BunnyCDN Stream (for video uploads via TUS direct browser upload)
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=

# BTCPay Server (self-hosted via LunaNode) — primary crypto path
BTCPAY_URL=
BTCPAY_STORE_ID=
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=

# --- AI-assisted story creation (Gemini 2.5 Flash) ---
# Google AI Studio API key (server-side only)
GEMINI_API_KEY=
# Set to "true" to enable the AI story wizard for verified creators
AI_STORY_WIZARD_ENABLED=false
# Daily USD budget ceiling. If today's estimated spend exceeds this,
# the wizard auto-disables itself for the rest of the UTC day.
AI_STORY_DAILY_BUDGET_USD=50

# --- Fiat-to-crypto on-ramps (pay with card, receive crypto) ---
# MoonPay partner keys: https://www.moonpay.com/business/ramps
# Publishable key used in URL params; secret key used to HMAC-sign the URL.
# Use sandbox keys (pk_test_… / sk_test_…) until KYB clears; flip to live
# keys after approval. Leave blank to hide MoonPay from the checkout picker.
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=
# Use "sandbox" for buy-sandbox.moonpay.com, "production" for buy.moonpay.com.
MOONPAY_ENVIRONMENT=sandbox
# Ramp partner key: https://rampnetwork.com (contact partner@ramp.network)
# Leave blank to hide Ramp from the checkout picker.
RAMP_API_KEY=
# Use "staging" for app.demo.ramp.network, "production" for app.ramp.network.
RAMP_ENVIRONMENT=staging
